#!/usr/bin/env bash
# claude-handoff: deprecation shim — forwards to claude-state.
# The project was renamed in v0.4.0; this shim keeps existing user
# muscle memory and external scripts that hardcoded the old name
# working through one minor cycle. Will be removed in v0.6.

printf 'claude-handoff: deprecated in v0.4.0, use `claude-state`. Forwarding.\n' >&2

# Try the canonical install path first, then fall back to a sibling
# claude-state in the same bin/ directory (repo case).
__cs_real="${CLAUDE_HOME:-$HOME/.claude}/bin/claude-state"
if [ -x "$__cs_real" ]; then
  exec "$__cs_real" "$@"
fi
__cs_sibling=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/claude-state
if [ -x "$__cs_sibling" ]; then
  exec "$__cs_sibling" "$@"
fi
echo "claude-handoff: cannot find claude-state. Re-run install.sh." >&2
exit 1
